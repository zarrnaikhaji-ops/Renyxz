{
  "version": 2,
  "functions": {
    "chat.js": {
      "maxDuration": 10
    }
  },
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/chat.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}